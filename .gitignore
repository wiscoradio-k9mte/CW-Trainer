# No trailing slash: also ignore a `node_modules` SYMLINK or file, not only a
# directory. A `node_modules/` pattern let a stray symlink get committed once.
node_modules
dist/
release/

# Local Claude Code settings + agent memory (personal, not for the public repo)
.claude/
.vite/
*.log
npm-debug.log*
.DS_Store

# Snapcraft build artifacts
*.snap
/parts/
/stage/
/prime/

# Internal team docs — kept locally as project memory, not for the public repo
/CLAUDE.md
/STATUS.md
/docs/

# Secrets / local environment files — never commit
.env
.env.*
*.env
# Credential files (e.g. snapcraft export-login output) — never commit; use Actions secrets
credentials.txt
*credentials*.txt
*.snapcraft
snapcraft-login*
*.macaroon
