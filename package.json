{
  "name": "wr-cw-trainer",
  "version": "2.3.0",
  "description": "CW Trainer by Wisco Radio Labs — learn Morse code with the Koch method, copy & sending practice, and a QSO simulator.",
  "keywords": [
    "morse",
    "cw",
    "ham-radio",
    "amateur-radio",
    "koch",
    "telegraph",
    "qso",
    "pota",
    "sota",
    "electron"
  ],
  "author": "Travis Engh (K9MTE) <wiscoradio@gmail.com>",
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/wiscoradio-k9mte/CW-Trainer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wiscoradio-k9mte/CW-Trainer.git"
  },
  "bugs": {
    "url": "https://github.com/wiscoradio-k9mte/CW-Trainer/issues"
  },
  "main": "electron/main.cjs",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "postinstall": "patch-package",
    "dev": "concurrently -k -n vite,electron -c blue,yellow \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "vite build",
    "preview": "vite preview",
    "start": "npm run build && electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --linux",
    "dist:snap": "npm run pack && snapcraft pack",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "overrides": {
    "shell-quote": "1.8.4"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.6",
    "jsdom": "^29.1.1",
    "patch-package": "^8.0.1",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  }
}
