{
  "name": "wr-cw-trainer",
  "version": "1.0.0",
  "description": "WISCO RADIO CW Trainer — learn Morse code with the Koch method, copy & sending practice, and a QSO simulator.",
  "author": "Travis Engh (K9MTE) <wiscoradio@gmail.com>",
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/wiscoradio-k9mte/CW-Trainer",
  "repository": {
    "type": "git",
    "url": "https://github.com/wiscoradio-k9mte/CW-Trainer.git"
  },
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,yellow \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "vite build",
    "preview": "vite preview",
    "start": "npm run build && electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --linux",
    "dist:snap": "npm run build && electron-builder --linux snap",
    "dist:flatpak": "npm run build && electron-builder --linux flatpak"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
